# ───────────────────────────────────────────────────────────────────────────
# Sprint H — Analytics + Pinterest (satış makinesi)
# ───────────────────────────────────────────────────────────────────────────

# GA4 — Google Analytics 4 (Property → Data Streams → Measurement ID)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# GA4 server-side (Measurement Protocol — Admin → Data Streams → MP API secret)
GA4_API_SECRET=

# Meta Pixel (Events Manager → Pixel → Pixel ID)
NEXT_PUBLIC_META_PIXEL_ID=
# Meta Conversions API (Events Manager → Settings → Generate Access Token)
META_CAPI_TOKEN=

# Pinterest Tag (Conversions → Tags → Tag ID, opsiyonel ama önerilir)
NEXT_PUBLIC_PINTEREST_TAG_ID=

# Pinterest OAuth App (developers.pinterest.com → Create app)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# Pinterest redirect URI — Production: https://fly-froth-social.vercel.app/api/auth/pinterest/callback
PINTEREST_OAUTH_REDIRECT_URI=https://fly-froth-social.vercel.app/api/auth/pinterest/callback
